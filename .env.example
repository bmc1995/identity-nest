# Runtime
PORT=3000
NODE_ENV=development

# Database (TypeORM / Postgres)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=identity
DATABASE_PASSWORD=identity
DATABASE_NAME=identity

# OIDC
OIDC_ISSUER=http://localhost:3000

# Dynamic Client Registration (RFC 7591)
# Initial access token gating the POST /oidc/register endpoint. Callers must
# send `Authorization: Bearer <this value>`. Leave unset to DISABLE dynamic
# registration entirely (the endpoint 403s and is omitted from discovery).
# MUST be a high-entropy secret in production.
# OIDC_REGISTRATION_ACCESS_TOKEN=
# Per-IP rate limit for POST /oidc/register (defence-in-depth, Redis-backed).
# Defaults: 10 requests per 3600s window.
# OIDC_REGISTRATION_RATE_LIMIT=10
# OIDC_REGISTRATION_RATE_WINDOW_SECONDS=3600

# HTTP
# Comma-separated list of allowed CORS origins (only needed when calling the
# IdP from a browser-based client; API testing tools like Postman/Bruno/Insomnia
# do not enforce CORS).
CORS_ORIGINS=http://localhost:8080,http://0.0.0.0:5173,https://localhost:5173/,https://127.0.0.1:5173/

# Session / cookie
SESSION_COOKIE_NAME=idp_session
SESSION_TTL_MS=3600000
# MUST be overridden in production — used to HMAC-sign session cookies
COOKIE_SECRET=dev-cookie-secret-change-in-production

# Tenant data encryption
# MUST be overridden in production
TENANT_ENCRYPTION_KEY=dev-key-change-in-production
